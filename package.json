{
  "name": "claude-viz",
  "version": "0.1.0",
  "description": "Local web dashboard for Claude Code CLI — subagent observatory + session scope receipt",
  "type": "module",
  "bin": { "claude-viz": "bin/claude-viz.js" },
  "main": "dist/server.js",
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "cd web && vite build",
    "build": "npm run build:server && npm run build:web",
    "dev:server": "tsc -p tsconfig.server.json --watch",
    "dev:web": "cd web && vite",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": ["bin", "dist", "scripts/hooks", "web/dist"],
  "engines": { "node": ">=20" },
  "dependencies": {
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
